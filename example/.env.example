# OIDC requires RS256 (asymmetric) signing. Generate an RSA private key ONCE and
# load its PEM here — do not generate on boot. The matching public key is derived
# automatically and published at /jwks.
#
#   openssl genpkey -algorithm RSA -pkcs8 -out private.pem -pkeyopt rsa_keygen_bits:2048
#
# Paste the PEM as a single line with literal \n, or load the file in code.
OAUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# The OIDC issuer — the public base URL of this server. Used as the `iss` claim
# and to build the discovery/JWKS/userinfo endpoint URLs.
OAUTH_ISSUER=http://localhost:3000
