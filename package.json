{
  "name": "@jmondi/oauth2-server",
  "version": "5.0.0-rc.4",
  "type": "module",
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "author": "Jason Raimondi <jason@raimondi.us>",
  "funding": "https://github.com/sponsors/jasonraimondi",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "start": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "format": "prettier --write \"**/*.{ts,js,tsx,md,mdx}\""
  },
  "repository": {
    "url": "https://github.com/jasonraimondi/ts-oauth2-server"
  },
  "exports": {
    ".": "./src/index.ts",
    "./vanilla": "./src/adapters/vanilla.ts",
    "./express": "./src/adapters/express.ts",
    "./fastify": "./src/adapters/fastify.ts",
    "./h3": "./src/adapters/h3.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./vanilla": {
        "import": {
          "types": "./dist/vanilla.d.ts",
          "default": "./dist/vanilla.js"
        },
        "require": {
          "types": "./dist/vanilla.d.cts",
          "default": "./dist/vanilla.cjs"
        }
      },
      "./express": {
        "import": {
          "types": "./dist/express.d.ts",
          "default": "./dist/express.js"
        },
        "require": {
          "types": "./dist/express.d.cts",
          "default": "./dist/express.cjs"
        }
      },
      "./fastify": {
        "import": {
          "types": "./dist/fastify.d.ts",
          "default": "./dist/fastify.js"
        },
        "require": {
          "types": "./dist/fastify.d.cts",
          "default": "./dist/fastify.cjs"
        }
      },
      "./h3": {
        "import": {
          "types": "./dist/h3.d.ts",
          "default": "./dist/h3.js"
        },
        "require": {
          "types": "./dist/h3.d.cts",
          "default": "./dist/h3.cjs"
        }
      }
    },
    "typesVersions": {
      "*": {
        "*": [
          "./dist/*",
          "./dist/index.d.ts"
        ]
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "h3": "1.15.11",
    "jose": "^6.2.3",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3"
  },
  "peerDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/ms": "^2.1.0",
    "h3": "^1.15.0"
  },
  "peerDependenciesMeta": {
    "@types/jsonwebtoken": {
      "optional": true
    },
    "@types/ms": {
      "optional": true
    },
    "h3": {
      "optional": true
    }
  }
}
